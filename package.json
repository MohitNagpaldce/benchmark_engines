{
  "name": "workflow-orchestration-benchmarks",
  "version": "1.0.0",
  "private": false,
  "description": "Open-source benchmark harness for comparing Temporal, Conductor, and Airflow workflow orchestration workloads.",
  "repository": {
    "type": "git",
    "url": "https://github.com/MohitNagpaldce/benchmark_engines.git"
  },
  "license": "GPL-3.0-only",
  "scripts": {
    "temporal:up": "docker-compose -f docker-compose.temporal.yml up -d",
    "temporal:down": "docker-compose -f docker-compose.temporal.yml down",
    "temporal:worker": "tsx src/engines/temporal/worker.ts",
    "temporal:bench": "tsx src/runner.ts --engine temporal",
    "observability:up": "docker-compose -f docker-compose.temporal.yml -f docker-compose.observability.yml up -d prometheus grafana",
    "observability:down": "docker-compose -f docker-compose.temporal.yml -f docker-compose.observability.yml down",
    "stack:up": "docker-compose -f docker-compose.temporal.yml -f docker-compose.observability.yml up -d",
    "stack:down": "docker-compose -f docker-compose.temporal.yml -f docker-compose.observability.yml down",
    "conductor:up": "docker-compose -f docker-compose.conductor.yml up -d",
    "conductor:down": "docker-compose -f docker-compose.conductor.yml down",
    "conductor:worker": "tsx src/engines/conductor/worker.ts",
    "conductor:bench": "tsx src/runner.ts --engine conductor",
    "airflow:up": "docker-compose -f docker-compose.airflow.yml up -d",
    "airflow:down": "docker-compose -f docker-compose.airflow.yml down",
    "airflow:bench": "tsx src/runner.ts --engine airflow",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@temporalio/activity": "^1.12.1",
    "@temporalio/client": "^1.12.1",
    "@temporalio/common": "^1.12.1",
    "@temporalio/worker": "^1.12.1",
    "@temporalio/workflow": "^1.12.1",
    "commander": "^12.1.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
